{
  "name": "vibecodr-openai-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:worker": "npx wrangler dev --config deploy/cloudflare/wrangler.gateway.toml",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test:auth": "node --import tsx --test test/mcpOAuthCompat.test.ts",
    "test:worker": "node --import tsx --test test/worker.test.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "deploy:gateway": "npx wrangler deploy --config deploy/cloudflare/wrangler.gateway.toml",
    "check": "tsc -p tsconfig.json --noEmit",
    "transport:regression": "npm run build && node scripts/mcp-transport-regression.mjs",
    "mcp:tools": "node scripts/list-mcp-tools.mjs",
    "mcp:measure": "node --import tsx scripts/measure-mcp-token-surface.mjs",
    "mcp:capability-evals": "node --import tsx scripts/capability-evals.mjs",
    "codemode:live-sandbox": "node scripts/codemode-live-sandbox-regression.mjs",
    "validate:env": "node scripts/validate-env.mjs",
    "security:preflight": "node scripts/security-preflight.mjs",
    "security:regression": "npm run build && node scripts/security-regression.mjs",
    "verify": "npm run check && npm test && npm run transport:regression && npm run security:regression && npm run mcp:capability-evals",
    "verify:release": "npm run verify && npm run codemode:live-sandbox"
  },
  "dependencies": {
    "@cloudflare/codemode": "^0.3.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
